// Niri Config - Managed by Home Manager
// KEYBINDINGS FOR COLEMAK LAYOUT (h n e i)

// --- Outputs (Displays) ---
output "eDP-1" {
    // Internal laptop display (ASUS ROG Flow X13)
    scale 2  // 125% scaling, adjust as needed
    background-color "#1e1e2e"  // Catppuccin Mocha base
}

// Uncomment and adjust for external monitors
// output "DP-2" {
//     position x=1920 y=0  // Place to the right of internal display
//     scale 1.0
//     background-color "#1e1e2e"
// }

// --- Input Devices ---
input {
    keyboard {
        xkb {
            layout "us,ru"
            variant "colemak,"
            options "grp:win_space_toggle,ctrl:nocaps"
        }
        repeat {
            delay 200
            rate 35
        }
    }
    
    touchpad {
        tap true
        natural-scroll true
        scroll-factor 1.0
        disable-while-typing true
    }
}

// --- Window Layout ---
layout {
    gaps 8
    
    border {
        width 2
        active-color "#cba6f7"   // Catppuccin Mocha mauve
        inactive-color "#6c7086"  // Catppuccin Mocha overlay0
    }
    
    focus-ring {
        width 2
        active-color "#f5c2e7"    // Catppuccin Mocha pink
    }
}

// --- COLEMAK KEY BINDINGS ---
// Based on physical key positions: h n e i (instead of h j k l)
binds {
    // Terminal (kitty)
    Mod+T { spawn "kitty"; }
    
    // Application launcher
    Mod+D { spawn "fuzzel"; }
    
    // Lock screen
    Mod+Alt+L { spawn "swaylock -f"; }
    
    // Screenshots
    ,Print { screenshot; }
    Mod+Shift+Print { screenshot-screen; }
    Mod+Ctrl+Print { screenshot-window; }
    
    // Quit
    Mod+Shift+E { quit; }

    // --- NAVIGATION (COLEMAK: h n e i) ---
    Mod+H { focus-column-left; }      // Left (H stays H)
    Mod+N { focus-window-down; }      // Down (J -> N)
    Mod+E { focus-window-up; }        // Up (K -> E)
    Mod+I { focus-column-right; }     // Right (L -> I)

    // --- MOVE WINDOWS (with Shift) ---
    Mod+Shift+H { move-column-left; }
    Mod+Shift+N { move-window-down; }
    Mod+Shift+E { move-window-up; }
    Mod+Shift+I { move-column-right; }

    // --- WORKSPACES ---
    Mod+U { focus-workspace-down; }    // Workspace down
    Mod+Y { focus-workspace-up; }      // Workspace up (I -> Y, рядом с U)
    
    Mod+Shift+U { move-workspace-down; }
    Mod+Shift+Y { move-workspace-up; }

    // Alternative: use brackets
    // Mod+LeftBracket { focus-workspace-down; }
    // Mod+RightBracket { focus-workspace-up; }

    // --- WINDOW OPERATIONS ---
    Mod+R { start-resizing; }
    Mod+F { fullscreen-window; }
    Mod+Shift+Q { close-window; }
    Mod+V { toggle-window-floating; }
    
    // Switch between tiled and floating
    Mod+Space { toggle-window-floating; }
    
    // Switch column width
    Mod+Comma { consume-window-into-column; }
    Mod+Period { expel-window-from-column; }
}

// --- Window Rules ---
window-rule {
    match app-id="vivaldi" {
        open-floating false
    }
    
    match app-id="pavucontrol" {
        open-floating true
    }
    
    match app-id="org.gnome.Nautilus" {
        open-floating true
    }
    
    match app-id="blueman-manager" {
        open-floating true
    }
}

// --- Autostart Services ---
spawn-at-startup "waybar"
spawn-at-startup "mako"
spawn-at-startup "swaybg" "-i" "/run/current-system/sw/share/backgrounds/nixos/nix-wallpaper.png"
spawn-at-startup "xwayland-satellite"

// --- Environment Variables ---
environment {
    DISPLAY ":0"
    XCURSOR_SIZE "24"
    XCURSOR_THEME "Adwaita"
    NIXOS_OZONE_WL "1"  // For Electron apps to use Wayland
}
